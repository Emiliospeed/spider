<Window x:Class="SPIGAIICode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SPIGAIICode"
        Title="G3 Servo Drive &amp; Robot Controller" Height="768" Width="1366" Background="#bdc3c7" WindowState="Maximized">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#23263a" CornerRadius="5" Padding="15" HorizontalAlignment="Left" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="COM Port:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                <ComboBox x:Name="PortCombo" Width="150" Height="30" VerticalContentAlignment="Center"/>
                <Button Content="Connect" Click="Connect_Click" Width="100" Margin="15,0,0,0" Background="#2e7d32" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                <Button x:Name="BtnDisconnect" Content="Disconnect" Click="Disconnect_Click" Width="100" Margin="10,0,0,0" IsEnabled="False" Background="#7f8c8d" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True" Background="White" Foreground="Black" 
                 BorderBrush="#34495e" BorderThickness="1" Margin="0,0,0,120" Width="400" HorizontalAlignment="Left"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="-10,113,10,0" Grid.RowSpan="2">

            <Border x:Name="RobotBox" Width="260" Height="508" Background="#d1d1d1" BorderBrush="#2c3e50" BorderThickness="1" Margin="0,0,20,0">
                <DockPanel LastChildFill="True">
                    <Border Background="#4a90e2" Height="35" DockPanel.Dock="Top">
                        <TextBlock Text="Robot 1" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Margin="10">
                        <TextBox x:Name="MessageBox" Height="60" IsReadOnly="True" Margin="0,0,0,15" Background="White" VerticalScrollBarVisibility="Auto"/>

                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Button x:Name="StartButton" Content="Start Server" Height="30" Margin="2" Click="StartButton_Click"/>
                            <Button x:Name="StopButton" Content="Stop Server" Height="30" Margin="2" Click="StopButton_Click"/>
                        </UniformGrid>

                        <Separator Margin="0,5"/>

                        <UniformGrid Columns="2" Margin="0,10">
                            <Button x:Name="Carrier1" Content="Carrier 1" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle1" Content="Shuttle 1" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier2" Content="Carrier 2" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle2" Content="Shuttle 2" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier3" Content="Carrier 3" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle3" Content="Shuttle 3" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier4" Content="Carrier 4" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle4" Content="Shuttle 4" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier5" Content="Carrier 5" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle5" Content="Shuttle 5" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier6" Content="Carrier 6" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle6" Content="Shuttle 6" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Carrier7" Content="Carrier 7" Height="28" Margin="2" Click="MotionButton_Click"/>
                            <Button x:Name="Shuttle7" Content="Shuttle 7" Height="28" Margin="2" Click="MotionButton_Click"/>
                        </UniformGrid>

                        <DockPanel Margin="0,10,0,0">
                            <Button x:Name="SetSpeedButton" Content="Set Speed" DockPanel.Dock="Right" Width="80" Height="28" Click="SetSpeedButton_Click"/>
                            <TextBox x:Name="SpeedBox" Text="50" Height="28" VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                        </DockPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <local:MotorControl x:Name="Motor1UI" Width="300" Height="501" Margin="0,0,20,0" Loaded="Motor1UI_Loaded" RenderTransformOrigin="0.5,0.5">
                <local:MotorControl.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="0.172"/>
                        <RotateTransform/>
                        <TranslateTransform X="0.797"/>
                    </TransformGroup>
                </local:MotorControl.RenderTransform>
            </local:MotorControl>

            <local:MotorControl x:Name="Motor2UI" Width="300" Height="495" />

        </StackPanel>
    </Grid>
</Window>